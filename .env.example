WHATSAPP_PHONE_ID=        # Business phone number ID
WHATSAPP_VERIFY_TOKEN=    # Webhook verification token
WHATSAPP_APP_SECRET=      # For HMAC-SHA256 signature validation

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MODEL_COMPLEX=claude-opus-4-6

# ─── M-Pesa Daraja ───────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=https://yourdomain.com/mpesa/callback

# ─── Cloudflare ──────────────────────────────────────────────────────────────
