# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dukabot:dukabot@localhost:5432/dukabot

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── WhatsApp Cloud API ──────────────────────────────────────────────────────
