    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
